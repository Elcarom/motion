+    const SettingsSectionDescriptor& descriptorFor(SettingsSection section) {
+      const auto it = std::ranges::find(kSettingsSections, section, &SettingsSectionDescriptor::section);
+      if (it == kSettingsSections.end()) {
+        std::abort();
+      }
+      return *it;
