+  const BarMonitorOverride* findMonitorOverride(const BarConfig& bar, std::string_view match) {
+    for (const auto& ovr : bar.monitorOverrides) {
+      if (ovr.match == match) {
+        return &ovr;
+      }
+    }
+    return nullptr;
+  }
